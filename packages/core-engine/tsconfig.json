{
  "extends": "@notrix/typescript-config/base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "lib": ["esnext", "dom", "webworker"],
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "downlevelIteration": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
